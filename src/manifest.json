{
  "manifest_version": 3,
  "name": "Tab Scissors Reforged",
  "version": "1.0.0",
  "description": "A modern, lightweight Chrome extension to split and merge your tabs.",
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "permissions": [
    "tabs",
    "windows"
  ],
  "action": {
    "default_title": "Tab Scissors Reforged",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "split-tabs": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Split tabs at current position"
    },
    "merge-windows": {
      "suggested_key": {
        "default": "Alt+A"
      },
      "description": "Merge all windows"
    }
  }
}
